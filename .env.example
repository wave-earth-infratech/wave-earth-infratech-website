# GitHub OAuth App credentials
# Create at: https://github.com/settings/developers → New OAuth App
# Authorization callback URL: https://www.waveearthinfratech.com/api/auth

GITHUB_OAUTH_CLIENT_ID=your_github_oauth_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_oauth_client_secret

# Live URL
NEXT_PUBLIC_SITE_URL=https://www.waveearthinfratech.com

# Contact form (nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password
CONTACT_TO_EMAIL=contact@waveearthinfratech.com
